# Minimal .gitignore for this Next.js + pnpm project

# Node modules
node_modules/

# Next.js build output
.next/
out/

# Production build folders
build/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment variables
.env
.env.local
.env.*.local

# Editor directories
.vscode/*
!.vscode/settings.json
.idea/

# OS files
.DS_Store
Thumbs.db

# TypeScript incremental build info
*.tsbuildinfo

# Coverage
coverage/

# Vercel
# Vercel
.vercel/

# Turborepo cache
.turbo/

# pnpm store (optional local cache)
.pnpm-store/

# General caches
.cache/

# pnpm store / PnP
.pnp

# Storybook static build
storybook-static/

# Ignore lockfiles only if you intentionally don't commit them (we keep pnpm-lock.yaml in this repo)
# Uncomment the following line if you do not want to commit lockfiles:
# pnpm-lock.yaml
next-env.d.ts
